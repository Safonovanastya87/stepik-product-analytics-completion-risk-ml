# --- Data Management ---
# Keep the data folder structure, but do not track raw or processed data files.
data/*

# Keep folder placeholder
!data/.gitkeep

# --- Generated Model Artifacts ---
# Models are generated by notebooks and should not be stored in Git.
models/*

# Keep folder placeholder
!models/.gitkeep

# --- Generated Results ---
# Results are generated by notebooks and should not be stored in Git.
results/*

# Keep folder placeholder
!results/.gitkeep

# --- Generated R / Python Artifacts ---
*.rds
*.Rds
*.pkl
*.joblib
*.feather
*.parquet

